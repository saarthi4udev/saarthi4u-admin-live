{
  "extends": [
    "development"
  ],
  "hints": {
    "typescript-config/is-valid": "off",
    "button-type": "off",
    "axe/name-role-value": [
      "default",
      {
        "button-name": "off"
      }
    ],
    "no-inline-styles": "off",
    "axe/forms": "off",
    "axe/aria": "off",
    "axe/structure": "off"
  },
  "browserslist": [
    "defaults",
    "not ie 11",
    "not chrome <= 109",
    "not ios_saf <= 17.5",
    "not safari <= 17.5",
    "not samsung <= 25",
    "not and_ff <= 126",
    "not firefox <= 126"
  ]
}